{
    "name": "snack/framework",
    "description": "Slim MVC micro-framework with a query builder/ORM, DI container, and PHP-rendered views enhanced by Vue islands.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "bramus/router": "~1.6",
        "vlucas/phpdotenv": "^5.5",
        "league/plates": "^3.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.9"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Snack\\": "snack/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Test\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyze ./snack/ ./app/ --level=6",
        "build": "@php bin/build.php"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
